{
  "name": "@odd-academia/db",
  "version": "0.1.0",
  "private": true,
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client.ts"
  },
  "scripts": {
    "build": "prisma generate",
    "db:generate": "prisma generate",
    "db:push":     "prisma db push",
    "db:migrate":  "prisma migrate dev",
    "db:seed":     "tsx src/seed.ts",
    "db:reset-admin": "tsx --env-file .env scripts/reset-admin.ts",
    "db:studio":   "prisma studio"
  },
  "prisma": {
    "seed": "tsx --env-file .env src/seed.ts"
  },
  "dependencies": {
    "@neondatabase/serverless": "^0.10.4",
    "@prisma/adapter-neon":    "^6.6.0",
    "@prisma/client":          "^6.6.0",
    "bcryptjs":                "^2.4.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node":     "^20",
    "prisma":          "^6.6.0",
    "tsx":             "^4.19.3",
    "typescript":      "^5"
  }
}
