# Neon PostgreSQL connection string
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require

# Secret for signing JWT tokens (use a long random string in production)
JWT_SECRET=your-jwt-secret-here

# Gmail credentials for sending verification/notification emails
GMAIL_USER=your-gmail@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Vercel Blob — required on Vercel for PDF + profile image uploads
# Auto-added when you connect a Blob store in the Vercel dashboard
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxx
