# Neon PostgreSQL connection string
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require

# Secret for signing JWT tokens (use a long random string in production)
JWT_SECRET=your-jwt-secret-here

# Gmail credentials for sending verification/notification emails
GMAIL_USER=your-gmail@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Vercel Blob — required on Vercel for PDF + profile image uploads
# Option A (recommended): connect Blob store to project → auto-adds BLOB_STORE_ID + VERCEL_OIDC_TOKEN
# Option B: enable read-write token when connecting → adds BLOB_READ_WRITE_TOKEN
BLOB_STORE_ID=store_xxxxxxxx
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxx
