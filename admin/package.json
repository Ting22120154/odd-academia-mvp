{
  "name": "admin",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -H 127.0.0.1 -p 3001",
    "build": "prisma generate --schema=../packages/db/prisma/schema.prisma && next build",
    "start": "next start -p 3001",
    "lint": "eslint",
    "create-admin": "tsx --env-file .env scripts/create-admin.ts",
    "test": "prisma generate --schema=../packages/db/prisma/schema.prisma && vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "prisma generate --schema=../packages/db/prisma/schema.prisma && vitest run tests/integration"
  },
  "dependencies": {
    "@odd-academia/db": "workspace:*",
    "@neondatabase/serverless": "^0.10.4",
    "@prisma/adapter-neon": "^6.6.0",
    "@prisma/client": "^6.6.0",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "next": "16.2.2",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "prisma": "^6.6.0",
    "tailwindcss": "^4",
    "tsx": "^4.19.3",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}
